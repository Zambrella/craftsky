{
  "lexicon": 1,
  "id": "social.craftsky.project.defs",
  "description": "Shared tokens for craft project details. These are used by multiple social.craftsky.project.* detail lexicons.",
  "defs": {
    "garment": {
      "type": "token",
      "description": "Clothing worn on the body."
    },
    "accessory": {
      "type": "token",
      "description": "Worn or carried accessories."
    },
    "homeGoods": {
      "type": "token",
      "description": "Household items and decor."
    },
    "toyHobby": {
      "type": "token",
      "description": "Toys, hobby objects, games, dolls, and play items."
    },
    "pet": {
      "type": "token",
      "description": "Pet clothing, bedding, toys, and accessories."
    },
    "medical": {
      "type": "token",
      "description": "Medical, adaptive, support, or care-related projects."
    },
    "component": {
      "type": "token",
      "description": "Motifs, swatches, parts, trims, blocks, appliques, or other components."
    },
    "quilt": {
      "type": "token",
      "description": "Quilts as a primary project category."
    },
    "alteration": {
      "type": "token",
      "description": "Mending, repair, refashioning, or adjustment of an existing item."
    },
    "costume": {
      "type": "token",
      "description": "Costume, cosplay, theatre, or fancy-dress projects."
    },
    "other": {
      "type": "token",
      "description": "Intentionally uncategorized or not covered by the current vocabulary."
    },
    "lace": {
      "type": "token",
      "description": "Lace weight yarn."
    },
    "fingering": {
      "type": "token",
      "description": "Fingering weight yarn."
    },
    "sport": {
      "type": "token",
      "description": "Sport weight yarn."
    },
