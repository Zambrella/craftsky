// Zed tasks for the Craftsky monorepo.
//
// The Flutter app lives under app/. Tasks that call Flutter or Dart directly
// use `cwd: "$ZED_WORKTREE_ROOT/app"`. Tasks that go through `just` use
// `cwd: "$ZED_WORKTREE_ROOT"` so the shared repo-level recipes can inject the
// same app config files used from the terminal.
//
// Docs: https://zed.dev/docs/tasks
[
  {
    "label": "LazyGit",
    "command": "lazygit",
    "shell": {
      "program": "sh"
    },
    "hide": "on_success",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  // ---------- Flutter run: per-device ----------
  //
  // Flutter app config is passed with --dart-define-from-file through the
  // matching `just app-run-*` recipes. Chrome / macOS / iOS simulator use
  // app/config/local.env. Android uses app/config/local-android.env because
  // Android routes localhost to the emulator itself, not the host.
  //
  // Port 18080 is the host-side mapping in docker-compose.yml; the
  // appview container itself listens on 8080 internally.
  {
    "label": "flutter run — Chrome",
    "command": "just",
    "args": [
      "app-run-chrome"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "flutter-run"
    ]
  },
  {
    "label": "flutter run",
    "command": "just",
    "args": [
      "app-run"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "flutter-run"
    ]
  },
  {
    "label": "flutter run — macOS",
    "command": "just",
    "args": [
      "app-run-macos"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "flutter-run"
    ]
  },
  {
    "label": "flutter run — iOS simulator",
    "command": "just",
    "args": [
      "app-run-ios"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "flutter-run"
    ]
  },
  {
    "label": "flutter run — Android emulator",
    "command": "just",
    "args": [
      "app-run-android"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "flutter-run"
    ]
  },
  // Interactive device picker — Flutter prompts in the terminal. This uses
  // local.env; use the Android emulator task for local-android.env.
  {
    "label": "flutter run — pick device",
    "command": "just",
    "args": [
      "app-run"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "flutter-run"
    ]
  },
  // ---------- Codegen ----------
  {
    "label": "build_runner: build (delete conflicting)",
    "command": "dart",
    "args": [
      "run",
      "build_runner",
      "build",
      "--delete-conflicting-outputs"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "codegen"
    ]
  },
  {
    "label": "build_runner: watch",
    "command": "dart",
    "args": [
      "run",
      "build_runner",
      "watch",
      "--delete-conflicting-outputs"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "codegen"
    ]
  },
  {
    "label": "flutter gen-l10n",
    "command": "flutter",
    "args": [
      "gen-l10n"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "codegen"
    ]
  },
  // ---------- Quality gate ----------
  {
    "label": "flutter analyze",
    "command": "just",
    "args": [
      "app-analyze"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "tags": [
      "check"
    ]
  },
  {
    "label": "custom_lint",
    "command": "dart",
    "args": [
      "run",
      "custom_lint"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "check"
    ]
  },
  {
    "label": "dart format .",
    "command": "dart",
    "args": [
      "format",
      "."
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "check"
    ]
  },
  // ---------- Tests ----------
  {
    "label": "flutter test",
    "command": "just",
    "args": [
      "app-test"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "tags": [
      "test"
    ]
  },
  // Run the test file currently open in Zed.
  {
    "label": "flutter test — current file",
    "command": "flutter",
    "args": [
      "test",
      "$ZED_RELATIVE_FILE"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "test"
    ]
  },
  // ---------- Builds ----------
  {
    "label": "flutter build web",
    "command": "just",
    "args": [
      "app-build-web"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "tags": [
      "build"
    ]
  },
  {
    "label": "flutter build ios — no codesign",
    "command": "just",
    "args": [
      "app-build-ios"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "tags": [
      "build"
    ]
  },
  {
    "label": "flutter build apk",
    "command": "just",
    "args": [
      "app-build-apk"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "tags": [
      "build"
    ]
  },
  // ---------- Housekeeping ----------
  {
    "label": "flutter pub get",
    "command": "flutter",
    "args": [
      "pub",
      "get"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "housekeeping"
    ]
  },
  {
    "label": "flutter pub upgrade",
    "command": "flutter",
    "args": [
      "pub",
      "upgrade"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "housekeeping"
    ]
  },
  {
    "label": "flutter clean",
    "command": "flutter",
    "args": [
      "clean"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "housekeeping"
    ]
  },
  {
    "label": "flutter doctor",
    "command": "flutter",
    "args": [
      "doctor",
      "-v"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/app",
    "reveal": "always",
    "tags": [
      "housekeeping"
    ]
  },
  // ---------- Backend (just recipes, for the full-stack loop) ----------
  {
    "label": "just dev",
    "command": "just",
    "args": [
      "dev"
    ],
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": [
      "backend"
    ]
  },
  {
    "label": "just test",
    "command": "just",
    "args": [
      "test"
    ],
    "reveal": "always",
    "tags": [
      "backend"
    ]
  }
]
