# Optional local-only AppView configuration.
#
# Copy this file to .env.local, keep that file out of source control, and
# recreate the AppView container after changing it. Generate the two
# CraftSky-owned secrets independently with: openssl rand -hex 32

# Enables the private Instagram data plane when populated with at least
# 32 bytes. This is independent from Meta's credentials.
INSTAGRAM_DATA_HMAC_KEY=

# Keep the external integration disabled until every value below is populated.
INSTAGRAM_META_ENABLED=false
# Start without automated replies while validating incoming webhooks.
INSTAGRAM_META_REPLIES_ENABLED=false

# Meta App Dashboard > App settings > Basic.
INSTAGRAM_META_APP_SECRET=
# A developer-chosen random value also entered in Meta's webhook setup.
INSTAGRAM_META_VERIFY_TOKEN=
# Long-lived Instagram User access token for the owned professional account.
INSTAGRAM_META_ACCESS_TOKEN=
# Numeric Instagram professional account user_id returned by GET /me.
INSTAGRAM_META_ACCOUNT_ID=

# Use the version configured for the Meta app and supported by the integration.
INSTAGRAM_META_API_VERSION=v25.0
INSTAGRAM_META_API_BASE_URL=https://graph.instagram.com
# Public Instagram URL opened when a member starts the DM challenge.
INSTAGRAM_META_DM_URL=https://www.instagram.com/craftskysocial/
