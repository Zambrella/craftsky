# Go
appview/bin/
appview/tmp/
*.test
*.out

# Env
.env
.env.local

# Dev-only media fixtures stay local; the directory README remains tracked.
appview/devmedia/*
!appview/devmedia/README.md

# Worktrees
.worktrees/
.claude/worktrees/

# Editors
.vscode/
.idea/
*.swp
.DS_Store

# Flutter ignores are in app/.gitignore (created by `flutter create`)

# Superpowers brainstorming artefacts
.superpowers/

# Sisyphus runtime files stay local; plans remain trackable.
.sisyphus/*
!.sisyphus/plans/
!.sisyphus/plans/*
