DATABASE_URL=postgres://craftsky:dev@localhost:5432/craftsky_dev?sslmode=disable
ALLOWED_ORIGINS=*
CRAFTSKY_DEV_DID=did:plc:jt3cxdyrhjhrkpwzdvonheax
TAP_WS_URL=ws://tap:2480/channel
TAP_ACK_TIMEOUT=10s
TAP_RECONNECT_MAX=30s
TAP_MAX_RETRIES=5

# scripts/compose-dev overrides this when readable local ADC is available.
# Without credentials, AppView starts normally with push delivery disabled.
PUSH_ENABLED=false

# Media limits. These defaults match the approved API contract.
MAX_POST_IMAGES=4
MAX_IMAGE_UPLOAD_BYTES=15728640

# Dev-only synthetic moderation controls.
APPVIEW_ENABLE_DEV_MODERATION=true
APPVIEW_DEV_MODERATION_TOKEN=local-dev-moderation-token

# OAuth (localhost mode — public client, no client secret).
# OAUTH_HOSTNAME intentionally unset in dev; this triggers oauth.NewLocalhostConfig.
OAUTH_HOSTNAME=
OAUTH_SCOPES=atproto transition:generic
OAUTH_SESSION_EXPIRY=4320h
OAUTH_SESSION_INACTIVITY=720h
OAUTH_AUTH_REQUEST_EXPIRY=30m
CRAFTSKY_SESSION_LAST_SEEN_THROTTLE=5m

# Observability. Hosted export is disabled unless SENTRY_DSN is set.
SENTRY_DSN=https://0db789277b730a641a533a2a0af32da9@o4511665947803648.ingest.de.sentry.io/4511665960517712
SENTRY_RELEASE=1.8.14
SENTRY_LOGS_ENABLED=true
SENTRY_TRACING_ENABLED=true
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_METRICS_ENABLED=true
SENTRY_TAP_TRACING_ENABLED=true
# Optional when Tap tracing is enabled.
SENTRY_TAP_TRACES_SAMPLE_RATE=1
# Local-only unsafe response-body logging remains disabled by default.
APPVIEW_UNSAFE_LOG_RESPONSE_BODIES=false

# Instagram
INSTAGRAM_DATA_HMAC_KEY=<independent random secret, at least 32 bytes>
INSTAGRAM_META_ENABLED=true
INSTAGRAM_META_REPLIES_ENABLED=false
INSTAGRAM_META_APP_SECRET=<Meta App Settings → Basic → App Secret>
INSTAGRAM_META_VERIFY_TOKEN=<random value chosen by us, at least 32 bytes>
INSTAGRAM_META_ACCESS_TOKEN=<generated Instagram user token>
INSTAGRAM_META_ACCOUNT_ID=<numeric user_id from /me>
INSTAGRAM_META_API_VERSION=v25.0
INSTAGRAM_META_API_BASE_URL=https://graph.instagram.com
INSTAGRAM_META_DM_URL=<public link that opens a DM/profile for craftskysocial>
