# Copy to prod.env and fill in real values. prod.env is gitignored.
# Required in prod:
DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME?sslmode=require
ALLOWED_ORIGINS=https://craftsky.social,https://www.craftsky.social
# CRAFTSKY_DEV_DID is ignored in prod; do not set.
TAP_WS_URL=ws://tap:2480/channel
TAP_ACK_TIMEOUT=10s
TAP_RECONNECT_MAX=30s
TAP_MAX_RETRIES=5

# OAuth (confidential client — required in prod).
# Generate the key locally with `just oauth-keygen` and paste the multibase output.
# Never commit real prod.env.
OAUTH_HOSTNAME=appview.craftsky.social
OAUTH_CLIENT_SECRET_KEY=
OAUTH_CLIENT_SECRET_KEY_ID=primary
OAUTH_SCOPES=atproto transition:generic
OAUTH_SESSION_EXPIRY=4320h
OAUTH_SESSION_INACTIVITY=720h
OAUTH_AUTH_REQUEST_EXPIRY=30m
CRAFTSKY_SESSION_LAST_SEEN_THROTTLE=5m

# Observability. With only SENTRY_DSN set, AppView sends classified errors and
# recovered panics. Logs, tracing, metrics, and Tap tracing require explicit
# flags because they are higher-volume signals. AppView does not expose /metrics.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_LOGS_ENABLED=false
SENTRY_TRACING_ENABLED=false
# Optional when tracing is enabled; defaults conservatively in prod if omitted.
# SENTRY_TRACES_SAMPLE_RATE=0.01
SENTRY_METRICS_ENABLED=false
SENTRY_TAP_TRACING_ENABLED=false
# Optional when Tap tracing is enabled; defaults conservatively in prod if omitted.
# SENTRY_TAP_TRACES_SAMPLE_RATE=0.01
# This is ignored/forced off in prod even if set.
APPVIEW_UNSAFE_LOG_RESPONSE_BODIES=false
